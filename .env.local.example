# ============================================================
# .env.local — 設備料卡管理系統環境變數
# 複製此檔為 .env.local 後填入實際值，勿 commit .env.local
# ============================================================

# ------ Supabase ------
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Project Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Project Settings → API → service_role key（伺服器端 / 批次腳本用，勿暴露給前端）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ------ Cloudinary ------
# Dashboard → Settings → Access Keys
# Cloud name（右上角顯示）
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# API Key / API Secret（Settings → Access Keys → Generate）
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 上傳預設資料夾（建議：equipment-cards）
CLOUDINARY_UPLOAD_FOLDER=equipment-cards

# ------ 應用程式 ------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Auth 登入限制（選填）------
# 若設定，只允許此網域的 Google 帳號登入（例如 eup.com.tw）
# 不設定則允許所有 Google 帳號
ALLOWED_EMAIL_DOMAIN=eup.com.tw
